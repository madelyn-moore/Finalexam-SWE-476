@model TaskFormViewModel
@{
    ViewData["Title"] = "Edit Task";
}

<section class="section-grid">
    <div class="col-8">
        <div class="surface-card">
            <div class="panel-header">
                <div>
                    <p class="eyebrow mb-1">Task Update</p>
                    <h2>Edit task in @Model.ProjectName</h2>
                </div>
            </div>

            <form asp-action="Edit" method="post">
                <input asp-for="Id" type="hidden" />
                <input asp-for="ProjectId" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                    <span asp-validation-for="Description" class="field-validation-error"></span>
                </div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Priority" class="form-label"></label>
                        <select asp-for="Priority" asp-items="Model.PriorityOptions" class="form-select"></select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DueDateUtc" class="form-label"></label>
                        <input asp-for="DueDateUtc" asp-format="{0:yyyy-MM-dd}" class="form-control" />
                    </div>
                </div>

                <div class="mt-3">
                    <label asp-for="AssignedToUserId" class="form-label"></label>
                    <select asp-for="AssignedToUserId" asp-items="Model.AssigneeOptions" class="form-select"></select>
                </div>

                <div class="button-row mt-4">
                    <button type="submit" class="btn btn-primary">Save Task</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-ghost">Back to Task</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
